---
/*
 * Tiny inline-SVG icon set. No external dependencies.
 * stroke="currentColor" so the icon picks up the current --fp-ink/-accent.
 */
interface Props {
  name:
    | 'shield' | 'sparkle' | 'bolt' | 'leaf' | 'medal' | 'clock'
    | 'star' | 'check' | 'phone' | 'mail' | 'pin' | 'arrow'
    | 'plus' | 'menu' | 'close';
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 24, class: className = '', strokeWidth = 1.75 } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  focusable="false"
>
  {name === 'shield' && (
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
  )}
  {name === 'sparkle' && (
    <>
      <path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8" />
    </>
  )}
  {name === 'bolt' && (
    <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" />
  )}
  {name === 'leaf' && (
    <>
      <path d="M11 20A7 7 0 0 1 4 13c0-7 11-9 17-9-1 6-3 17-10 17z" />
      <path d="M2 22l8-8" />
    </>
  )}
  {name === 'medal' && (
    <>
      <circle cx="12" cy="14" r="6" />
      <path d="M8.5 14l-2 7 5.5-3 5.5 3-2-7" />
      <path d="M8 2l4 6 4-6" />
    </>
  )}
  {name === 'clock' && (
    <>
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" />
    </>
  )}
  {name === 'star' && (
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88L2 9.27l6.91-1.01L12 2z" fill="currentColor" stroke="none" />
  )}
  {name === 'check' && (
    <path d="M5 12l5 5L20 7" />
  )}
  {name === 'phone' && (
    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
  )}
  {name === 'mail' && (
    <>
      <rect x="2" y="4" width="20" height="16" rx="2" />
      <path d="M2 7l10 6 10-6" />
    </>
  )}
  {name === 'pin' && (
    <>
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
      <circle cx="12" cy="10" r="3" />
    </>
  )}
  {name === 'arrow' && (
    <path d="M5 12h14M13 6l6 6-6 6" />
  )}
  {name === 'plus' && (
    <path d="M12 5v14M5 12h14" />
  )}
  {name === 'menu' && (
    <path d="M3 6h18M3 12h18M3 18h18" />
  )}
  {name === 'close' && (
    <path d="M6 6l12 12M6 18L18 6" />
  )}
</svg>
