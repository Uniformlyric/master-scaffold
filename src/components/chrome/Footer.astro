---
import { siteDna } from '../../lib/siteDna';
import {
  defaultContactInfo,
  realOrDefaultServices,
  businessInitials,
} from '../../lib/defaults';
import Icon from '../Icon.astro';

const { businessInfo, assets } = siteDna;
const name = businessInfo.name ?? 'Your Business';
const initials = businessInitials(businessInfo);
const contact = defaultContactInfo(businessInfo);
const services = realOrDefaultServices(businessInfo).slice(0, 5);
const logo = assets.logo;
const year = new Date().getFullYear();
---

<footer
  class="fp-footer fp-tone-bg"
  style="border-top: 1px solid var(--fp-border-on-bg);"
>
  <div class="mx-auto grid w-full max-w-[80rem] gap-10 px-6 py-16 md:grid-cols-12">
    <div class="md:col-span-4">
      <a href="#top" class="flex items-center gap-3" aria-label={`${name} home`}>
        {logo ? (
          <img
            src={logo.downloadURL}
            alt={`${name} logo`}
            class="h-9 w-auto"
            width={logo.width}
            height={logo.height}
          />
        ) : (
          <span
            class="flex h-9 w-9 items-center justify-center font-display text-sm font-bold"
            style="background: color-mix(in oklab, var(--fp-on-bg) 18%, transparent); color: var(--fp-on-bg); border-radius: var(--fp-radius);"
          >
            {initials}
          </span>
        )}
        <span class="font-display text-lg font-semibold" style="color: var(--fp-on-bg)">
          {name}
        </span>
      </a>
      <p class="mt-4 text-sm leading-relaxed" style="color: var(--fp-on-bg-muted)">
        {businessInfo.valueProp ?? `${name} is a trusted local team delivering reliable, high-quality service backed by hundreds of five-star reviews.`}
      </p>
    </div>

    <div class="md:col-span-3">
      <h4 class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--fp-on-bg)">
        Services
      </h4>
      <ul class="mt-4 space-y-2 text-sm">
        {services.map((s) => (
          <li>
            <a href="#services" class="hover:underline" style="color: var(--fp-on-bg-muted)">
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-3">
      <h4 class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--fp-on-bg)">
        Contact
      </h4>
      <ul class="mt-4 space-y-3 text-sm" style="color: var(--fp-on-bg-muted)">
        <li class="flex items-center gap-2">
          <Icon name="phone" size={14} />
          <a href={contact.phoneHref} class="hover:underline">{contact.phone}</a>
        </li>
        <li class="flex items-center gap-2">
          <Icon name="mail" size={14} />
          <a href={contact.emailHref} class="hover:underline">{contact.email}</a>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="clock" size={14} class="mt-0.5" />
          <span>{contact.hours}</span>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="pin" size={14} class="mt-0.5" />
          <span>{contact.address}</span>
        </li>
      </ul>
    </div>

    <div class="md:col-span-2">
      <h4 class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--fp-on-bg)">
        Follow
      </h4>
      <ul class="mt-4 space-y-2 text-sm">
        {contact.socials.map((s) => (
          <li>
            <a href={s.href} class="hover:underline" style="color: var(--fp-on-bg-muted)">
              {s.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div
    class="mx-auto flex w-full max-w-[80rem] flex-col items-center justify-between gap-3 px-6 py-6 text-xs sm:flex-row"
    style="color: var(--fp-on-bg-muted); border-top: 1px solid var(--fp-border-on-bg);"
  >
    <p>&copy; {year} {name}. All rights reserved.</p>
    <p class="opacity-80">Built with Flashpoint</p>
  </div>
</footer>
