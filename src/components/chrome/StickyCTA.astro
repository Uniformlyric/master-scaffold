---
import { siteDna } from '../../lib/siteDna';
import { defaultContactInfo } from '../../lib/defaults';
import Icon from '../Icon.astro';

const contact = defaultContactInfo(siteDna.businessInfo);
---

<div
  class="fp-sticky-cta fixed inset-x-0 bottom-0 z-50 md:hidden"
  style="background: var(--fp-bg); border-top: 1px solid var(--fp-border-on-bg); box-shadow: 0 -8px 24px -12px color-mix(in oklab, var(--fp-on-bg) 25%, transparent);"
>
  <div class="grid grid-cols-2 gap-2 p-3">
    <a
      href={contact.phoneHref}
      class="fp-button-outline justify-center text-sm"
      style="color: var(--fp-on-bg); border-color: var(--fp-border-on-bg);"
    >
      <Icon name="phone" size={16} class="mr-2" />
      Call
    </a>
    <a href="#contact" class="fp-button justify-center text-sm">
      <Icon name="mail" size={16} class="mr-2" />
      Get a quote
    </a>
  </div>
</div>

<style>
  /* Add bottom padding so content isn't covered by the sticky bar on mobile. */
  @media (max-width: 767px) {
    body {
      padding-bottom: 5rem;
    }
  }
</style>
