---
import { siteDna } from '../../lib/siteDna';
import { resolveShellMeta } from '../../lib/layoutShell';

const gallery = siteDna.assets.gallery ?? [];
const before = gallery[0];
const after = gallery[1] ?? siteDna.assets.hero;
const meta = resolveShellMeta(siteDna);
const maskClass = `nm-mask-${meta.defaultMask}`;
const driftAttr: string | undefined = meta.drift === 'none' ? undefined : meta.drift;
---

<section class="fp-section nm-leak-field" data-reveal>
  <div class="max-w-3xl">
    <h2 class="font-display text-4xl font-semibold md:text-5xl lg:text-6xl" style="font-family: var(--nm-font-display, var(--fp-font-display)); color: var(--fp-ink); letter-spacing: -0.015em; line-height: 0.98;">
      Before &amp; after.
    </h2>
    <p class="mt-5 max-w-prose text-base md:text-lg" style="color: var(--fp-muted)">A look at the transformation our clients see.</p>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-2">
    {[
      { asset: before, label: 'Before', accent: false },
      { asset: after, label: 'After', accent: true },
    ].map(({ asset, label, accent }, idx) => (
      <figure
        class:list={[
          'fp-card relative overflow-hidden p-0 nm-rs-md',
          maskClass,
          idx === 1 && meta.peelStrength >= 1 && 'md:translate-y-6',
        ]}
        data-drift={idx === 1 ? driftAttr : undefined}
      >
        <div class="relative">
          {asset ? (
            <img
              src={asset.downloadURL}
              alt={asset.alt ?? label}
              class="nm-cinematic block aspect-video w-full object-cover"
              loading="lazy"
              width={asset.width}
              height={asset.height}
            />
          ) : (
            <div
              class="flex aspect-video items-center justify-center font-mono text-xs uppercase tracking-widest"
              style="background: color-mix(in oklab, var(--fp-ink) 6%, transparent); color: var(--fp-muted);"
            >
              {label} placeholder
            </div>
          )}
          <span
            class="absolute left-3 top-3 px-3 py-1 font-mono text-[11px] font-bold uppercase tracking-widest"
            style={accent
              ? `background: var(--nm-accent, var(--fp-accent)); color: var(--nm-on-accent, var(--fp-on-accent)); border-radius: var(--nm-radius-pill);`
              : `background: color-mix(in oklab, var(--fp-ink) 75%, transparent); color: var(--fp-bg); border-radius: var(--nm-radius-pill);`}
          >
            {label}
          </span>
        </div>
      </figure>
    ))}
  </div>
</section>
