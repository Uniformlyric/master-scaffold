---
import { siteDna } from '../../lib/siteDna';
const gallery = siteDna.assets.gallery ?? [];
const before = gallery[0];
const after = gallery[1] ?? siteDna.assets.hero;
---

<section class="fp-section" data-reveal>
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--fp-accent)">
      Real results
    </p>
    <h2
      class="mt-3 font-display text-3xl font-semibold md:text-4xl lg:text-5xl"
      style="color: var(--fp-ink)"
    >
      Before &amp; after
    </h2>
    <p class="mt-4 text-base md:text-lg" style="color: var(--fp-muted)">
      A look at the transformation our clients see.
    </p>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-2">
    {[
      { asset: before, label: 'Before', accent: false },
      { asset: after, label: 'After', accent: true },
    ].map(({ asset, label, accent }) => (
      <figure class="fp-card relative overflow-hidden p-0">
        <div class="relative">
          {asset ? (
            <img
              src={asset.downloadURL}
              alt={asset.alt ?? label}
              class="block aspect-video w-full object-cover"
              loading="lazy"
              width={asset.width}
              height={asset.height}
            />
          ) : (
            <div
              class="flex aspect-video items-center justify-center text-xs uppercase tracking-widest"
              style="background: color-mix(in oklab, var(--fp-ink) 6%, transparent); color: var(--fp-muted);"
            >
              {label} placeholder
            </div>
          )}
          <span
            class="absolute left-3 top-3 px-3 py-1 text-[11px] font-bold uppercase tracking-widest"
            style={accent
              ? `background: var(--fp-accent); color: var(--fp-on-accent); border-radius: var(--fp-radius);`
              : `background: color-mix(in oklab, var(--fp-ink) 75%, transparent); color: var(--fp-bg); border-radius: var(--fp-radius);`}
          >
            {label}
          </span>
        </div>
      </figure>
    ))}
  </div>
</section>
