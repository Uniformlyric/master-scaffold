---
import { siteDna } from '../../lib/siteDna';
import { businessInitials } from '../../lib/defaults';
import { resolveShellMeta } from '../../lib/layoutShell';
import Icon from '../Icon.astro';
import MonogramFigure from '../MonogramFigure.astro';

/*
 * NM CTA banner - asymmetric "leaked card" composition.
 *
 * Old version: solid accent-color rectangle, centered headline, two
 * centered CTA buttons. Reads as a banner ad inserted between sections.
 *
 * New version:
 *   60/40 asymmetric grid
 *   left 60%: italic display statement at clamp(2.5rem,7vw,6rem),
 *             two CTAs stacked vertically (primary + secondary), all left-aligned
 *   right 40%: single masked drift figure that peels INTO the footer below
 *   background tone: obsidian (no solid accent rectangle)
 *   two leaks at opposing corners (accent tl, secondary br)
 *   nm-peel-2 so it breaks the FAQ section above by ~8vh
 */

const name = siteDna.businessInfo.name ?? 'us';
const initials = businessInitials(siteDna.businessInfo);
const meta = resolveShellMeta(siteDna);
const heroAsset = siteDna.assets.hero;
const galleryAsset = siteDna.assets.gallery?.[1] ?? siteDna.assets.gallery?.[0];
const peelMedia = heroAsset ?? galleryAsset;

const driftAttr: string | undefined = meta.drift === 'none' ? undefined : meta.drift;
---

<section
  class="nm-cta fp-section nm-leak-field nm-tone-obsidian nm-peel-2"
  data-tone="obsidian"
  data-shell={meta.id}
  data-reveal
>
  <span class="nm-leak nm-leak--1 nm-leak--tl" aria-hidden="true"></span>
  <span class="nm-leak nm-leak--2 nm-leak--br" aria-hidden="true"></span>

  <span class="nm-label nm-label--corner-tl">{meta.number} / Begin</span>
  <span class="nm-label nm-label--corner-br">SHEET / END</span>

  <div class="nm-cta__grid">
    <div class="nm-cta__copy">
      <p class="nm-cta__pre">A correspondence in two parts</p>
      <h2 class="nm-cta__headline">
        Let&rsquo;s
        <span class="nm-cta__headline-em">begin</span>
        with
        <br class="nm-cta__br-md" />
        {name}.
      </h2>

      <p class="nm-cta__lede">
        A short call, a clear scope, an honest quote.
        No high-pressure follow-ups, ever.
      </p>

      <div class="nm-cta__buttons">
        <a href="#contact" class="nm-cta__primary">
          <span>Get a free quote</span>
          <Icon name="arrow" size={18} class="ml-2" />
        </a>
        <a href="#services" class="nm-cta__secondary">
          <span>Browse the practice</span>
        </a>
      </div>
    </div>

    <div class="nm-cta__figure" data-drift={driftAttr}>
      <figure class="nm-cta__media nm-mask-blob-b">
        {peelMedia ? (
          <img
            src={peelMedia.downloadURL}
            alt=""
            class="nm-cinematic"
            loading="lazy"
            width={peelMedia.width}
            height={peelMedia.height}
          />
        ) : (
          <MonogramFigure initials={initials} />
        )}
      </figure>
    </div>
  </div>
</section>

<style is:inline>
  .nm-cta {
    position: relative;
    overflow: hidden;
    padding-block: clamp(7rem, 14vh, 11rem);
  }

  .nm-cta__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    align-items: end;
    gap: 3rem;
    max-width: 88rem;
    margin: 0 auto;
    padding: 0 clamp(1rem, 3vw, 2rem);
  }
  @media (min-width: 1024px) {
    .nm-cta__grid {
      grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
      gap: 4rem;
    }
  }

  .nm-cta__copy {
    min-width: 0;
  }

  .nm-cta__pre {
    font-family: var(--nm-font-mono, ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--nm-accent, var(--fp-accent));
    margin-bottom: 1.25rem;
  }

  .nm-cta__headline {
    font-family: var(--nm-font-display, var(--fp-font-display));
    color: var(--fp-ink);
    font-size: clamp(2.75rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
    font-weight: 600;
  }
  .nm-cta__headline-em {
    font-family: var(--nm-font-italic, Georgia, serif);
    font-style: italic;
    font-weight: 400;
    color: var(--nm-accent, var(--fp-accent));
    padding: 0 0.15ch;
  }
  .nm-cta__br-md {
    display: none;
  }
  @media (min-width: 1024px) {
    .nm-cta__br-md { display: inline; }
  }

  .nm-cta__lede {
    margin-top: 1.75rem;
    max-width: 32rem;
    font-size: 1.05rem;
    line-height: 1.6;
    color: color-mix(in oklab, var(--fp-ink) 80%, transparent);
  }

  .nm-cta__buttons {
    margin-top: 2.25rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
  }
  .nm-cta__primary {
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 1.65rem;
    background: var(--nm-accent, var(--fp-accent));
    color: var(--nm-on-accent, var(--fp-on-accent));
    border-radius: 999px;
    font-family: var(--nm-font-mono, ui-monospace, monospace);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 220ms;
  }
  .nm-cta__primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px -12px color-mix(in oklab, var(--nm-accent, var(--fp-accent)) 65%, transparent);
  }
  .nm-cta__secondary {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    padding: 0.55rem 0;
    color: var(--fp-ink);
    font-family: var(--nm-font-mono, ui-monospace, monospace);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--fp-ink) 30%, transparent);
    transition: border-color 200ms, color 200ms;
  }
  .nm-cta__secondary:hover {
    color: var(--nm-accent, var(--fp-accent));
    border-color: var(--nm-accent, var(--fp-accent));
  }

  /* Right-side peeling figure. */
  .nm-cta__figure {
    position: relative;
    align-self: stretch;
    min-height: 320px;
  }
  .nm-cta__media {
    position: relative;
    width: 100%;
    min-width: 280px;
    max-width: 480px;
    margin-left: auto;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    transform: rotate(-2deg) translateY(8%);
  }
  @media (min-width: 1024px) {
    .nm-cta__media {
      /* Pull the figure down so it peels INTO the footer below. */
      transform: rotate(-2deg) translateY(18%);
    }
  }
  .nm-cta__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
