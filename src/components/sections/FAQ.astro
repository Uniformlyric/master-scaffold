---
import { siteDna } from '../../lib/siteDna';
import { defaultFAQs } from '../../lib/defaults';
import { resolveShellMeta } from '../../lib/layoutShell';
import Icon from '../Icon.astro';

const allFaqs = defaultFAQs(siteDna.businessInfo);
const meta = resolveShellMeta(siteDna);

/* Density hint - quiet shells show 4, standard 5, busy 6. */
const limit = meta.density === 'quiet' ? 4 : meta.density === 'busy' ? 6 : 5;
const faqs = allFaqs.slice(0, limit);
---

<section id="faq" class="fp-section nm-leak-field" data-reveal>
  {meta.density !== 'quiet' && (
    <span class="nm-leak nm-leak--2 nm-leak--bl" aria-hidden="true"></span>
  )}

  <div class="mx-auto max-w-3xl">
    <h2
      class="font-display text-4xl font-semibold md:text-5xl lg:text-6xl"
      style="font-family: var(--nm-font-display, var(--fp-font-display)); color: var(--fp-ink); letter-spacing: -0.015em; line-height: 0.98;"
    >
      Frequently asked.
    </h2>
    <p class="mt-5 max-w-prose text-base md:text-lg" style="color: var(--fp-muted)">
      Don&rsquo;t see what you&rsquo;re looking for? Reach out and we&rsquo;ll get back to you the same day.
    </p>
  </div>

  <div class="mx-auto mt-10 max-w-3xl">
    {faqs.map((faq, idx) => (
      <details
        class="group fp-faq-item"
        style="border-bottom: var(--fp-border-width) solid var(--fp-border-color);"
      >
        <summary
          class="flex cursor-pointer list-none items-baseline justify-between gap-4 py-5 text-base font-semibold md:text-lg"
          style="color: var(--fp-ink)"
        >
          <span class="flex items-baseline gap-3">
            {meta.exposedRules && (
              <span class="font-mono text-[10px] uppercase tracking-[0.18em]" style="color: var(--fp-muted)">
                N°{String(idx + 1).padStart(2, '0')}
              </span>
            )}
            <span>{faq.q}</span>
          </span>
          <span
            class="flex h-8 w-8 shrink-0 items-center justify-center transition-transform group-open:rotate-45"
            style="border: var(--fp-border-width) solid var(--fp-border-color); border-radius: 999px; color: var(--nm-accent, var(--fp-accent));"
          >
            <Icon name="plus" size={16} />
          </span>
        </summary>
        <p class="pb-5 pr-12 text-sm leading-relaxed md:text-base" style="color: var(--fp-muted)">
          {faq.a}
        </p>
      </details>
    ))}
  </div>
</section>

<style>
  .fp-faq-item summary::-webkit-details-marker { display: none; }
</style>
