---
import { siteDna } from '../../lib/siteDna';
const gallery = siteDna.assets.gallery ?? [];
---

<section class="fp-section">
  <h2 class="font-display text-3xl font-semibold md:text-4xl" style="color: var(--fp-ink)">
    Gallery
  </h2>

  {
    gallery.length === 0 ? (
      <p class="mt-4 text-sm" style="color: var(--fp-muted)">
        Photos coming soon.
      </p>
    ) : (
      <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-4">
        {gallery.map((img) => (
          <figure>
            <img
              src={img.downloadURL}
              alt={img.alt ?? ''}
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
              style="border-radius: var(--fp-radius); border: var(--fp-border-width) solid color-mix(in oklab, var(--fp-ink) 12%, transparent)"
              width={img.width}
              height={img.height}
            />
          </figure>
        ))}
      </div>
    )
  }
</section>
