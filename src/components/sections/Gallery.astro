---
import { siteDna } from '../../lib/siteDna';
const gallery = siteDna.assets.gallery ?? [];
---

<section class="fp-section" data-reveal>
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--fp-accent)">
      Selected work
    </p>
    <h2
      class="mt-3 font-display text-3xl font-semibold md:text-4xl lg:text-5xl"
      style="color: var(--fp-ink)"
    >
      Gallery
    </h2>
  </div>

  {gallery.length === 0 ? (
    <p class="mt-10 text-center text-sm" style="color: var(--fp-muted)">
      Photos coming soon.
    </p>
  ) : (
    <>
      <div
        class="mt-12 hidden gap-3 md:grid md:grid-cols-3 lg:grid-cols-4"
      >
        {gallery.map((img) => (
          <figure class="group overflow-hidden" style="border-radius: var(--fp-radius); border: var(--fp-border-width) solid var(--fp-border-color);">
            <img
              src={img.downloadURL}
              alt={img.alt ?? ''}
              loading="lazy"
              class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
              width={img.width}
              height={img.height}
            />
          </figure>
        ))}
      </div>

      <div class="-mx-6 mt-12 overflow-x-auto px-6 md:hidden" style="scroll-snap-type: x mandatory;">
        <div class="flex gap-3">
          {gallery.map((img) => (
            <figure
              class="shrink-0 overflow-hidden"
              style="width: 80%; border-radius: var(--fp-radius); border: var(--fp-border-width) solid var(--fp-border-color); scroll-snap-align: start;"
            >
              <img
                src={img.downloadURL}
                alt={img.alt ?? ''}
                loading="lazy"
                class="aspect-[4/3] w-full object-cover"
                width={img.width}
                height={img.height}
              />
            </figure>
          ))}
        </div>
      </div>
    </>
  )}
</section>
