---
import { siteDna } from '../../lib/siteDna';
import { resolveShellMeta } from '../../lib/layoutShell';

const gallery = siteDna.assets.gallery ?? [];
const meta = resolveShellMeta(siteDna);

/**
 * Gallery variant resolution.
 *
 *  mosaic-mask     - organic masked figures in a 3-4 col mosaic (default)
 *  scroll-rail     - horizontal scroll rail at fixed height
 *  floating-shapes - decorative floating asymmetric figures
 */
function galleryVariantFor(shellId: string): 'mosaic-mask' | 'scroll-rail' | 'floating-shapes' {
  switch (shellId) {
    case 'cabinet':
    case 'marquee':
      return 'scroll-rail';
    case 'drift':
    case 'cascade':
    case 'atrium':
      return 'floating-shapes';
    default:
      return 'mosaic-mask';
  }
}

const variant = galleryVariantFor(meta.id);
const masks = ['nm-mask-blob', 'nm-mask-pill', 'nm-mask-blob-b', 'nm-mask-lozenge', 'nm-mask-blob-c', 'nm-mask-capsule'];
---

<section
  class="fp-section nm-leak-field"
  data-reveal
  data-shell-gallery={variant}
>
  <div class="max-w-3xl">
    <h2 class="font-display text-4xl font-semibold md:text-5xl lg:text-6xl" style="font-family: var(--nm-font-display, var(--fp-font-display)); color: var(--fp-ink); letter-spacing: -0.015em; line-height: 0.98;">
      Selected work.
    </h2>
  </div>

  {gallery.length === 0 && (
    <p class="mt-10 text-center text-sm" style="color: var(--fp-muted)">Photos coming soon.</p>
  )}

  {gallery.length > 0 && variant === 'mosaic-mask' && (
    <div class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4 lg:gap-5">
      {gallery.map((img, i) => (
        <figure
          class:list={[
            'group relative overflow-hidden nm-rs-md',
            masks[i % masks.length],
            i % 4 === 0 ? 'aspect-[3/4]' : i % 4 === 1 ? 'aspect-square' : i % 4 === 2 ? 'aspect-[4/5]' : 'aspect-[5/4]',
            i % 3 === 1 && 'md:translate-y-4',
            i % 3 === 2 && 'md:-translate-y-2',
          ]}
        >
          <img
            src={img.downloadURL}
            alt={img.alt ?? ''}
            loading="lazy"
            class="nm-cinematic block h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            width={img.width}
            height={img.height}
          />
        </figure>
      ))}
    </div>
  )}

  {gallery.length > 0 && variant === 'scroll-rail' && (
    <div class="-mx-6 mt-12 overflow-x-auto px-6" style="scroll-snap-type: x mandatory;">
      <div class="flex gap-5">
        {gallery.map((img, i) => (
          <figure
            class:list={[
              'shrink-0 overflow-hidden nm-rs-md',
              i % 2 === 0 ? 'nm-mask-pill' : 'nm-mask-capsule',
            ]}
            style="width: 320px; height: 400px; scroll-snap-align: start;"
          >
            <img src={img.downloadURL} alt={img.alt ?? ''} loading="lazy" class="nm-cinematic block h-full w-full object-cover" width={img.width} height={img.height} />
          </figure>
        ))}
      </div>
    </div>
  )}

  {gallery.length > 0 && variant === 'floating-shapes' && (
    <div class="relative mt-16 min-h-[600px]">
      <span class="nm-leak nm-leak--2 nm-leak--alive nm-leak--c" aria-hidden="true"></span>
      <div class="relative grid gap-6 md:grid-cols-12">
        {gallery.slice(0, 5).map((img, i) => {
          const drift = i % 2 === 0 ? 'slow' : 'fast';
          const positions = [
            'md:col-start-1 md:col-span-5 md:row-start-1',
            'md:col-start-7 md:col-span-4 md:row-start-1 md:translate-y-12',
            'md:col-start-2 md:col-span-3 md:row-start-2 md:-translate-y-6',
            'md:col-start-6 md:col-span-5 md:row-start-2 md:translate-y-4',
            'md:col-start-9 md:col-span-4 md:row-start-3 md:-translate-y-8',
          ];
          const aspects = ['aspect-[4/5]', 'aspect-square', 'aspect-[5/4]', 'aspect-[3/4]', 'aspect-[4/3]'];
          return (
            <figure
              class:list={['relative overflow-hidden', masks[i % masks.length], aspects[i] ?? 'aspect-square', positions[i] ?? '']}
              data-drift={drift}
            >
              <img src={img.downloadURL} alt={img.alt ?? ''} loading="lazy" class="nm-cinematic block h-full w-full object-cover" width={img.width} height={img.height} />
            </figure>
          );
        })}
      </div>
    </div>
  )}
</section>
