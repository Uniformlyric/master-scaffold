---
import { siteDna } from '../../lib/siteDna';
import {
  defaultHeroEyebrow,
  defaultValueProp,
  businessInitials,
  trustMicroRow,
} from '../../lib/defaults';
import Icon from '../Icon.astro';

const { businessInfo, assets, designTokens } = siteDna;
const eyebrow = defaultHeroEyebrow(businessInfo, designTokens.vibe);
const valueProp = defaultValueProp(businessInfo);
const initials = businessInitials(businessInfo);
const trust = trustMicroRow(businessInfo);

/*
 * Hero asset selection rules:
 * - real hero asset that does NOT match the logo storagePath -> use it
 * - missing OR matches the logo -> render a vibe-tinted gradient + monogram block
 *   (never paste the logo as a giant photo, that always reads as a stretched logo)
 */
const heroAsset = assets.hero;
const logoAsset = assets.logo;
const useRealHero = Boolean(
  heroAsset && (!logoAsset || heroAsset.storagePath !== logoAsset.storagePath),
);
---

<section id="top" class="fp-section py-24 md:py-32" data-reveal>
  <div class="grid items-center gap-10 md:grid-cols-12 md:gap-12">
    <div class="md:col-span-7 min-w-0">
      <p
        class="text-xs font-semibold uppercase tracking-[0.18em]"
        style="color: var(--fp-accent)"
      >
        {eyebrow}
      </p>
      <h1
        class="mt-5 font-display text-5xl font-bold leading-[1.05] tracking-tight md:text-6xl lg:text-7xl"
        style="color: var(--fp-ink)"
      >
        {businessInfo.name ?? 'Your Business'}
      </h1>
      <p
        class="mt-6 max-w-xl text-lg leading-relaxed md:text-xl"
        style="color: var(--fp-muted)"
      >
        {valueProp}
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="#contact" class="fp-button text-base">
          Get a free quote
          <Icon name="arrow" size={18} class="ml-2" />
        </a>
        <a href="#services" class="fp-button-outline text-base">See services</a>
      </div>

      <ul
        class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm"
        style="color: var(--fp-muted)"
      >
        <li class="flex items-center gap-1.5">
          <span class="flex" style="color: var(--fp-accent)">
            {Array.from({ length: 5 }).map(() => <Icon name="star" size={14} />)}
          </span>
          <span style="color: var(--fp-ink)" class="font-semibold">
            {trust.rating}
          </span>
          <span>· {trust.reviews}</span>
        </li>
        <li class="hidden items-center gap-1.5 sm:flex">
          <Icon name="medal" size={14} />
          <span>{trust.years} in business</span>
        </li>
        <li class="hidden items-center gap-1.5 md:flex">
          <Icon name="check" size={14} />
          <span>{trust.jobs}</span>
        </li>
      </ul>
    </div>

    <div class="md:col-span-5 min-w-0">
      <figure
        class="relative mx-auto max-h-[560px] w-full max-w-[480px] overflow-hidden"
        style="border-radius: var(--fp-radius); border: var(--fp-border-width) solid var(--fp-border-color); aspect-ratio: 4 / 5;"
      >
        {useRealHero && heroAsset ? (
          <img
            src={heroAsset.downloadURL}
            alt={heroAsset.alt ?? businessInfo.name ?? 'hero'}
            class="block h-full w-full object-cover"
            style="object-position: center;"
            loading="eager"
            width={heroAsset.width}
            height={heroAsset.height}
          />
        ) : (
          <div
            class="relative flex h-full w-full items-center justify-center"
            style={`background:
              radial-gradient(circle at 30% 30%, color-mix(in oklab, var(--fp-accent) 65%, transparent), transparent 60%),
              radial-gradient(circle at 70% 70%, color-mix(in oklab, var(--fp-warm-1, var(--fp-accent)) 50%, transparent), transparent 65%),
              color-mix(in oklab, var(--fp-accent) 18%, var(--fp-bg));`}
          >
            <span
              class="font-display text-[7rem] font-bold leading-none tracking-tight md:text-[9rem]"
              style="color: var(--fp-on-accent); mix-blend-mode: normal; text-shadow: 0 4px 24px color-mix(in oklab, var(--fp-on-accent) 25%, transparent);"
            >
              {initials}
            </span>
          </div>
        )}
      </figure>
    </div>
  </div>
</section>
