---
import { siteDna } from '../../lib/siteDna';
import { businessInitials } from '../../lib/defaults';
import { resolveShellMeta } from '../../lib/layoutShell';

const logo = siteDna.assets.logo;
const name = siteDna.businessInfo.name ?? '';
const initials = businessInitials(siteDna.businessInfo);
const meta = resolveShellMeta(siteDna);
const maskClass = `nm-mask-${meta.defaultMask}`;
---

<section class="fp-section py-12" data-reveal>
  <div class="flex flex-col items-center gap-3 text-center">
    {logo ? (
      <img
        src={logo.downloadURL}
        alt={logo.alt ?? `${name} logo`}
        class="h-20 w-auto"
        width={logo.width}
        height={logo.height}
      />
    ) : (
      <span
        class:list={['flex h-20 w-20 items-center justify-center font-display text-2xl font-bold', maskClass]}
        style="background: color-mix(in oklab, var(--nm-accent, var(--fp-accent)) 18%, transparent); color: var(--nm-accent, var(--fp-accent));"
      >
        {initials}
      </span>
    )}
    {name && (
      <p class="font-display text-lg" style="font-family: var(--nm-font-display, var(--fp-font-display)); color: var(--fp-ink)">
        {name}
      </p>
    )}
  </div>
</section>
