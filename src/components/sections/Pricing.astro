---
import { siteDna } from '../../lib/siteDna';
import { defaultPricingTiers, realOrDefaultServices } from '../../lib/defaults';
import { resolveShellMeta } from '../../lib/layoutShell';
import Icon from '../Icon.astro';

const services = realOrDefaultServices(siteDna.businessInfo);
const tiers = defaultPricingTiers(siteDna.businessInfo, services);
const meta = resolveShellMeta(siteDna);

/**
 * Pricing variant resolution.
 *
 *  stacked-cards  - 3 columns, middle highlighted (default, broadest fit)
 *  editorial-rows - 3 rows in a price ledger, hairline-separated
 *  marquee-tier   - one giant tier statement that drops the comparison framing
 */
function pricingVariantFor(shellId: string): 'stacked-cards' | 'editorial-rows' | 'marquee-tier' {
  switch (shellId) {
    case 'ledger':
    case 'portico':
    case 'letterhead':
      return 'editorial-rows';
    case 'marquee':
    case 'drift':
      return 'marquee-tier';
    default:
      return 'stacked-cards';
  }
}

const variant = pricingVariantFor(meta.id);
const featured = tiers.find((t) => t.highlight) ?? tiers[1] ?? tiers[0];
---

<section
  id="pricing"
  class="fp-section nm-leak-field"
  data-reveal
  data-shell-pricing={variant}
>
  <div class="grid items-end gap-8 md:grid-cols-12">
    <h2 class="md:col-span-9 font-display font-semibold" style="font-family: var(--nm-font-display, var(--fp-font-display)); color: var(--fp-ink); font-size: clamp(2.75rem, 7vw, 5.5rem); letter-spacing: -0.025em; line-height: 0.95;">
      Transparent. <span style="font-family: var(--nm-font-italic, Georgia, serif); font-style: italic; font-weight: 400;">Up front.</span> No surprises.
    </h2>
    <p class="md:col-span-3 max-w-prose text-base md:text-lg" style="color: var(--fp-muted)">
      Pick a tier or call us for a custom quote. We do the math, you get the price.
    </p>
  </div>

  {variant === 'stacked-cards' && (
    <div class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-3 md:items-end md:gap-10 md:pb-6">
      {tiers.map((tier, idx) => {
        /*
         * 3-tier ledger - center card sits HIGHER (translateY -3vh) and
         * the side cards sit slightly lower at different amounts so the
         * top edges of all three are uneven, like sheets of paper sliding
         * out of a portfolio.
         */
        const offsets = ['md:translate-y-[3vh]', 'md:-translate-y-[3vh]', 'md:translate-y-[6vh]'];
        return (
        <article
          class:list={[
            'fp-card relative flex h-full flex-col',
            offsets[idx % offsets.length],
            tier.highlight && 'md:shadow-2xl',
          ]}
          style={tier.highlight
            ? `border-radius: var(--nm-radius-md, var(--fp-radius)); border-width: 2px; border-color: var(--nm-accent, var(--fp-accent)); background: color-mix(in oklab, var(--nm-accent, var(--fp-accent)) 6%, transparent);`
            : 'border-radius: var(--nm-radius-md, var(--fp-radius));'}
        >
          {tier.highlight && (
            <span
              class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 font-mono text-[11px] font-bold uppercase tracking-widest"
              style="background: var(--nm-accent, var(--fp-accent)); color: var(--nm-on-accent, var(--fp-on-accent)); border-radius: var(--nm-radius-pill);"
            >
              Most Popular
            </span>
          )}
          <h3 class="font-display text-xl font-semibold" style="color: var(--fp-ink)">{tier.name}</h3>
          <p class="mt-2 text-sm" style="color: var(--fp-muted)">{tier.description}</p>
          <p class="mt-6 font-display text-3xl font-bold md:text-4xl" style="color: var(--nm-accent, var(--fp-accent))">{tier.priceLabel}</p>
          <ul class="mt-6 flex-1 space-y-3 text-sm">
            {tier.features.map((f) => (
              <li class="flex items-start gap-2" style="color: var(--fp-ink)">
                <span class="mt-0.5" style="color: var(--nm-accent, var(--fp-accent))"><Icon name="check" size={16} strokeWidth={2.5} /></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a href="#contact" class={tier.highlight ? 'fp-button mt-8' : 'fp-button-outline mt-8'}>{tier.ctaLabel}</a>
        </article>
        );
      })}
    </div>
  )}

  {variant === 'editorial-rows' && (
    <div class="mx-auto mt-12 max-w-4xl">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b" style="border-color: var(--fp-border-color)">
            <th class="py-3 font-mono text-[10px] uppercase tracking-widest" style="color: var(--fp-muted)">Tier</th>
            <th class="py-3 font-mono text-[10px] uppercase tracking-widest" style="color: var(--fp-muted)">Price</th>
            <th class="hidden py-3 font-mono text-[10px] uppercase tracking-widest md:table-cell" style="color: var(--fp-muted)">Includes</th>
            <th class="py-3 text-right font-mono text-[10px] uppercase tracking-widest" style="color: var(--fp-muted)"></th>
          </tr>
        </thead>
        <tbody>
          {tiers.map((tier) => (
            <tr class:list={['border-b align-top', tier.highlight && 'bg-current/5']} style="border-color: var(--fp-border-color)">
              <td class="py-6 align-top">
                <p class="font-display text-2xl font-semibold tracking-tight" style="color: var(--fp-ink)">{tier.name}</p>
                {tier.highlight && (
                  <span class="mt-1 inline-block font-mono text-[10px] uppercase tracking-widest" style="color: var(--nm-accent, var(--fp-accent))">Most popular</span>
                )}
                <p class="mt-2 text-sm" style="color: var(--fp-muted)">{tier.description}</p>
              </td>
              <td class="py-6 align-top">
                <p class="font-display text-3xl font-bold" style="color: var(--nm-accent, var(--fp-accent))">{tier.priceLabel}</p>
              </td>
              <td class="hidden py-6 align-top md:table-cell">
                <ul class="space-y-2 text-sm" style="color: var(--fp-ink)">
                  {tier.features.slice(0, 4).map((f) => (
                    <li class="flex items-start gap-2">
                      <span style="color: var(--nm-accent, var(--fp-accent))"><Icon name="check" size={14} /></span>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
              </td>
              <td class="py-6 text-right align-top">
                <a href="#contact" class={tier.highlight ? 'fp-button' : 'fp-button-outline'}>{tier.ctaLabel}</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {variant === 'marquee-tier' && featured && (
    <div class="relative mt-16">
      <span class="nm-leak nm-leak--3 nm-leak--alive nm-leak--c" aria-hidden="true"></span>
      <div class="relative mx-auto max-w-3xl text-center">
        <h3 class="font-display font-bold leading-[0.92] tracking-[-0.025em]" style="font-family: var(--nm-font-display, var(--fp-font-display)); color: var(--fp-ink); font-size: clamp(3.5rem, 11vw, 9rem);">
          {featured.priceLabel}
        </h3>
        <p class="mt-6 text-lg" style="color: var(--fp-muted)">{featured.description}</p>
        <ul class="mx-auto mt-8 grid max-w-xl gap-2 text-left text-sm md:grid-cols-2">
          {featured.features.slice(0, 6).map((f) => (
            <li class="flex items-start gap-2" style="color: var(--fp-ink)">
              <span class="mt-0.5" style="color: var(--nm-accent, var(--fp-accent))"><Icon name="check" size={14} /></span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
          <a href="#contact" class="fp-button text-base">{featured.ctaLabel} <Icon name="arrow" size={18} class="ml-2" /></a>
          <a href="#services" class="fp-button-outline text-base">All services</a>
        </div>
      </div>
      <div class="mt-12 grid gap-3 text-center md:grid-cols-3">
        {tiers.map((t) => (
          <div class="rounded-lg p-3 font-mono text-xs" style="background: color-mix(in oklab, var(--fp-ink) 5%, transparent); border: 1px solid var(--fp-border-color); border-radius: var(--nm-radius-sm, var(--fp-radius));">
            <span style="color: var(--fp-ink)">{t.name}</span>
            <span class="mx-2" style="color: var(--fp-muted)">·</span>
            <span style="color: var(--nm-accent, var(--fp-accent))">{t.priceLabel}</span>
          </div>
        ))}
      </div>
    </div>
  )}
</section>
