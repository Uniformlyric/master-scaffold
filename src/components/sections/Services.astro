---
import { siteDna } from '../../lib/siteDna';
const services = siteDna.businessInfo.services ?? [];
---

<section id="services" class="fp-section">
  <h2 class="font-display text-3xl font-semibold md:text-4xl" style="color: var(--fp-ink)">
    Services
  </h2>
  <p class="mt-2" style="color: var(--fp-muted)">What we offer.</p>

  <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      services.map((service) => (
        <article class="fp-card">
          <h3 class="font-display text-xl font-semibold" style="color: var(--fp-ink)">
            {service.title}
          </h3>
          {service.description && (
            <p class="mt-2 text-sm" style="color: var(--fp-muted)">
              {service.description}
            </p>
          )}
          {service.priceLabel && (
            <p class="mt-4 text-sm font-semibold" style="color: var(--fp-accent)">
              {service.priceLabel}
            </p>
          )}
        </article>
      ))
    }
  </div>
</section>
