---
import { siteDna } from '../../lib/siteDna';
import { realOrDefaultServices } from '../../lib/defaults';
import Icon from '../Icon.astro';

const services = realOrDefaultServices(siteDna.businessInfo);
---

<section id="services" class="fp-section" data-reveal>
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--fp-accent)">
      What we do
    </p>
    <h2
      class="mt-3 font-display text-3xl font-semibold md:text-4xl lg:text-5xl"
      style="color: var(--fp-ink)"
    >
      Services that move the needle
    </h2>
    <p class="mt-4 text-base md:text-lg" style="color: var(--fp-muted)">
      Pick the package that fits. Every job ships with the same craftsmanship and a written satisfaction guarantee.
    </p>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {services.slice(0, 6).map((service, idx) => (
      <article
        class="fp-card group flex h-full flex-col transition-transform duration-200 hover:-translate-y-1"
        style="border-left-width: 4px; border-left-style: solid; border-left-color: var(--fp-accent);"
      >
        <div class="flex items-center gap-3">
          <span
            class="inline-flex h-9 w-9 items-center justify-center font-display text-sm font-bold"
            style="background: color-mix(in oklab, var(--fp-accent) 18%, transparent); color: var(--fp-accent); border-radius: var(--fp-radius);"
          >
            {String(idx + 1).padStart(2, '0')}
          </span>
          <h3
            class="font-display text-xl font-semibold"
            style="color: var(--fp-ink)"
          >
            {service.title}
          </h3>
        </div>

        {service.description && (
          <p class="mt-4 flex-1 text-sm leading-relaxed md:text-base" style="color: var(--fp-muted)">
            {service.description}
          </p>
        )}

        <div class="mt-6 flex items-center justify-between gap-4">
          {service.priceLabel && (
            <p class="text-sm font-semibold" style="color: var(--fp-accent)">
              {service.priceLabel}
            </p>
          )}
          <a
            href="#contact"
            class="inline-flex items-center gap-1 text-sm font-semibold transition-colors group-hover:opacity-80"
            style="color: var(--fp-ink)"
          >
            Learn more
            <Icon name="arrow" size={14} />
          </a>
        </div>
      </article>
    ))}
  </div>
</section>
