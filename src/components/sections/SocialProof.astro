---
const logos = [
  'Yelp - 5.0',
  'Google - 4.9',
  'Angi - Top Pro',
  'BBB A+',
  'NextDoor Fav',
];
---

<section class="fp-section">
  <p
    class="text-center text-xs uppercase tracking-widest"
    style="color: var(--fp-muted)"
  >
    Trusted by neighbors and reviewers across the region
  </p>
  <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-4 opacity-80">
    {
      logos.map((label) => (
        <span class="font-display text-sm font-semibold" style="color: var(--fp-ink)">
          {label}
        </span>
      ))
    }
  </div>
</section>
