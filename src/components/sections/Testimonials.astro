---
import { siteDna } from '../../lib/siteDna';
import { defaultTestimonials } from '../../lib/defaults';
import Icon from '../Icon.astro';

const testimonials = defaultTestimonials(siteDna.businessInfo);
---

<section id="testimonials" class="fp-section" data-reveal>
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--fp-accent)">
      Real reviews
    </p>
    <h2
      class="mt-3 font-display text-3xl font-semibold md:text-4xl lg:text-5xl"
      style="color: var(--fp-ink)"
    >
      What customers say
    </h2>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-3">
    {testimonials.map((t) => (
      <figure class="fp-card flex h-full flex-col">
        <div class="flex items-center gap-1" style="color: var(--fp-accent)">
          {Array.from({ length: 5 }).map(() => <Icon name="star" size={16} />)}
        </div>
        <blockquote
          class="mt-4 flex-1 text-base leading-relaxed md:text-lg"
          style="color: var(--fp-ink)"
        >
          &ldquo;{t.quote}&rdquo;
        </blockquote>
        <figcaption class="mt-6 flex items-center gap-3">
          <span
            class="flex h-10 w-10 items-center justify-center font-display text-sm font-bold"
            style="background: color-mix(in oklab, var(--fp-accent) 22%, transparent); color: var(--fp-accent); border-radius: 999px;"
          >
            {t.initials}
          </span>
          <div class="text-sm">
            <p class="font-semibold" style="color: var(--fp-ink)">{t.name}</p>
            <p style="color: var(--fp-muted)">{t.role}</p>
          </div>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
