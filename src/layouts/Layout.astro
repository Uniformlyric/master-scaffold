---
import '../styles/global.css';
import '../styles/signature.css';
import '../styles/vibes.css';
import { GOOGLE_FONTS_HREF_BY_VIBE } from '../site-dna/index.js';
import { siteDna } from '../lib/siteDna';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ?? siteDna.businessInfo.name ?? 'Flashpoint Site';
const pageDescription =
  description ?? siteDna.businessInfo.valueProp ?? siteDna.businessInfo.tagline ?? '';
const vibe = siteDna.designTokens.vibe;
const signature = siteDna.designTokens.signature;
const vibeFontsHref = GOOGLE_FONTS_HREF_BY_VIBE[vibe];

/*
 * Nuzum Method core type system - always loaded so the 4 type roles
 * (display grotesque / body sans / mono labels / serif italic accent)
 * are available regardless of which vibe-specific display face is
 * loaded by GOOGLE_FONTS_HREF_BY_VIBE.
 *
 * Curated to what every NM flavor falls back to:
 *   - Inter             (body sans, universal)
 *   - Space Grotesk     (display grotesque, universal fallback)
 *   - JetBrains Mono    (label monospace, universal)
 *   - Cormorant Garamond (italic accent, universal fallback)
 */
const nmCoreFontsHref =
  'https://fonts.googleapis.com/css2?' +
  'family=Inter:wght@400;500;600;700&' +
  'family=Space+Grotesk:wght@400;500;600;700&' +
  'family=JetBrains+Mono:wght@400;500&' +
  'family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&' +
  'display=swap';

const palette = siteDna.designTokens.multiTonePalette;
const typography = siteDna.designTokens.typography;

/*
 * Per-lead override block.
 *
 * Under the Nuzum Method signature the obsidian/moss/paper base is owned
 * by signature.css; we ONLY allow per-lead overrides for the accent and
 * the type letter-spacing/radius fine-tuning. This keeps every NM site
 * looking unmistakably "Nuzum" while still respecting wizard-level taste.
 *
 * Under any future signature (e.g. 'classic') we'd fall back to the
 * legacy full palette injection.
 */
const isNuzum = signature === 'nuzum-method';
const overrideStyle = isNuzum
  ? [
      `--nm-accent: ${palette.accent};`,
      `--fp-accent: ${palette.accent};`,
      typography.letterSpacing ? `--fp-letter-spacing: ${typography.letterSpacing};` : '',
    ]
      .filter(Boolean)
      .join(' ')
  : [
      `--fp-bg: ${palette.surfaceVariants[0] ?? palette.coolTones[0] ?? palette.warmTones[0] ?? '#0F172A'};`,
      `--fp-surface: ${palette.surfaceVariants[1] ?? palette.warmTones[0] ?? palette.coolTones[1] ?? '#1F2937'};`,
      palette.warmTones[0] ? `--fp-warm-1: ${palette.warmTones[0]};` : '',
      palette.coolTones[0] ? `--fp-cool-1: ${palette.coolTones[0]};` : '',
      `--fp-accent: ${palette.accent};`,
      palette.ink ? `--fp-ink: ${palette.ink};` : '',
      palette.muted ? `--fp-muted: ${palette.muted};` : '',
      `--fp-font-display: ${typography.headingStack};`,
      `--fp-font-body: ${typography.bodyStack};`,
      `--fp-radius: ${typography.borderRadius};`,
      `--fp-border-width: ${typography.borderWidth};`,
      typography.letterSpacing ? `--fp-letter-spacing: ${typography.letterSpacing};` : '',
    ]
      .filter(Boolean)
      .join(' ');
---

<!doctype html>
<html lang="en" data-vibe={vibe} data-signature={signature}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {isNuzum && <link rel="stylesheet" href={nmCoreFontsHref} />}
    <link rel="stylesheet" href={vibeFontsHref} />
    <style is:inline set:html={`:root { ${overrideStyle} }`}></style>
  </head>
  <body>
    {/*
      Scalable blob masks for .nm-mask-blob / -b / -c (see signature.css).
      clipPathUnits="objectBoundingBox" so clip scales with figure size;
      CSS clip-path: path() used fixed ~200px coords and showed tiny slivers.
    */}
    <svg
      aria-hidden="true"
      focusable="false"
      width="0"
      height="0"
      style="position:absolute;width:0;height:0;overflow:hidden"
    >
      <defs>
        <clipPath id="nm-mask-blob" clipPathUnits="objectBoundingBox">
          <path
            d="M0.78 0.25c0.07 0.09 0.1 0.24 0.04 0.34-0.05 0.1-0.18 0.16-0.3 0.16-0.12 0.01-0.24-0.04-0.32-0.12-0.08-0.08-0.12-0.21-0.08-0.3 0.04-0.1 0.16-0.17 0.27-0.2 0.12-0.03 0.23-0.01 0.3 0.03 0.07 0.04 0.11 0.12 0.09 0.09z"
          />
        </clipPath>
        <clipPath id="nm-mask-blob-b" clipPathUnits="objectBoundingBox">
          <path
            d="M0.84 0.35c0.06 0.11 0.04 0.28-0.06 0.38-0.1 0.1-0.25 0.12-0.36 0.08-0.11-0.04-0.19-0.13-0.22-0.25-0.03-0.12 0-0.26 0.09-0.35 0.09-0.09 0.23-0.13 0.35-0.09 0.12 0.04 0.14 0.12 0.2 0.23z"
          />
        </clipPath>
        <clipPath id="nm-mask-blob-c" clipPathUnits="objectBoundingBox">
          <path
            d="M0.75 0.15c0.15 0.09 0.2 0.28 0.16 0.42-0.04 0.14-0.17 0.25-0.31 0.28-0.14 0.03-0.29-0.02-0.36-0.13-0.07-0.11-0.06-0.27 0.02-0.39 0.08-0.12 0.22-0.22 0.35-0.22 0.09 0 0.11 0.02 0.14 0.04z"
          />
        </clipPath>
      </defs>
    </svg>
    <slot />
  </body>
</html>
